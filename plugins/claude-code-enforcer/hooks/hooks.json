{
  "description": "Airlock enforcer — gates tool use through gateway/mobile approval",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/airlock-session.js\" start",
            "timeout": 5,
            "statusMessage": "Airlock: starting daemon..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/airlock-session.js\" stop",
            "timeout": 3
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/airlock-bootstrap.js\"",
            "timeout": 130,
            "statusMessage": "Airlock: waiting for approval..."
          }
        ]
      }
    ]
  }
}
